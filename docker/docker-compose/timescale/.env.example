# PostgreSQL Configuration
ATULYA_DB_USER=atulya_user
ATULYA_DB_PASSWORD=change-me-to-secure-password
ATULYA_DB_NAME=atulya_db

# Atulya Version
ATULYA_VERSION=latest

# LLM Configuration
ATULYA_API_LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Alternative LLM providers (uncomment and configure as needed):
# ATULYA_API_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ATULYA_API_LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key

# ATULYA_API_LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key

# Vector and Text Search (already configured in docker-compose.yaml)
# ATULYA_API_VECTOR_EXTENSION=pgvectorscale
# ATULYA_API_TEXT_SEARCH_EXTENSION=pg_textsearch

# Entity trajectories (optional; default off — set true to enable async trajectory recompute after retain)
# ATULYA_API_ENABLE_ENTITY_TRAJECTORIES=false
# ATULYA_API_ENTITY_TRAJECTORY_MAX_FACTS_PER_ENTITY=200
# ATULYA_API_ENTITY_TRAJECTORY_FORECAST_HORIZON=5
# ATULYA_API_ENTITY_TRAJECTORY_LAPLACE_ALPHA=0.1
# ATULYA_API_ENTITY_TRAJECTORY_MIN_FACTS=3
# ATULYA_API_ENTITY_TRAJECTORY_ENQUEUE_MAX_ENTITIES=50
# ATULYA_API_ENTITY_TRAJECTORY_PROMPT_VERSION=v1
