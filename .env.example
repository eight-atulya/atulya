# Atulya Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (Required)
# Supported providers: openai, groq, ollama, gemini, anthropic, anthropic-foundry, lmstudio, vertexai
# ATULYA_API_LLM_PROVIDER=openai
# ATULYA_API_LLM_API_KEY=your-api-key-here
# ATULYA_API_LLM_MODEL=gpt-4o-mini
# ATULYA_API_LLM_BASE_URL=https://api.openai.com/v1

# Example: Anthropic Claude configuration
# ATULYA_API_LLM_PROVIDER=anthropic
# ATULYA_API_LLM_API_KEY=your-anthropic-api-key
# ATULYA_API_LLM_MODEL=claude-sonnet-4-20250514

# Example: Anthropic via Azure AI Foundry
# ATULYA_API_LLM_PROVIDER=anthropic-foundry
# ATULYA_API_LLM_API_KEY=your-azure-ai-foundry-key
# ATULYA_API_LLM_MODEL=claude-sonnet-4-6
# ATULYA_API_LLM_BASE_URL=https://your-endpoint.services.ai.azure.com/anthropic/

# Example: Google Vertex AI configuration
# ATULYA_API_LLM_PROVIDER=vertexai
# ATULYA_API_LLM_MODEL=google/gemini-2.0-flash-001
# ATULYA_API_LLM_VERTEXAI_PROJECT_ID=your-gcp-project-id
# ATULYA_API_LLM_VERTEXAI_REGION=us-central1
# ATULYA_API_LLM_VERTEXAI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json  # Optional, uses ADC if not set

# Example: LM Studio local configuration (openai/gpt-oss-20b recommended)
ATULYA_API_LLM_PROVIDER=lmstudio
ATULYA_API_LLM_API_KEY=lmstudio
ATULYA_API_LLM_BASE_URL=http://localhost:1234/v1
ATULYA_API_LLM_MODEL=openai/gpt-oss-20b

# LM Studio stability note:
# - Keep reasoning effort at "medium" in your LM Studio/runtime settings.
# - For newer OpenAI-style models, set experts to 8 in LM Studio model settings.
# - Recommended minimum: openai/gpt-oss-20b on RTX 4060 with full GPU offload
#   for okay-ish performance and better accuracy.

# API Configuration (Optional)
ATULYA_API_HOST=0.0.0.0
ATULYA_API_PORT=8888
ATULYA_API_LOG_LEVEL=info

# Brain Configuration [required]
ATULYA_API_BRAIN_ENABLED=true
ATULYA_API_BRAIN_STARTUP_WARMUP=true

# Base Path / Reverse Proxy Support (Optional)
# Set these when deploying behind a reverse proxy with path-based routing
# Example: To deploy at example.com/atulya/, set both to "/atulya"
# ATULYA_API_BASE_PATH=/atulya
# NEXT_PUBLIC_BASE_PATH=/atulya

# Database (Optional - uses embedded pg0 by default)
# ATULYA_API_DATABASE_URL=postgresql://user:pass@host:5432/db
# ATULYA_API_DATABASE_SCHEMA=public  # PostgreSQL schema name (default: public)

# Vector Extension (Optional - uses pgvector by default)
# Options: "pgvector" (default), "vchord", "pgvectorscale" (DiskANN)
# ATULYA_API_VECTOR_EXTENSION=pgvector
# For Azure PostgreSQL with DiskANN:
# ATULYA_API_VECTOR_EXTENSION=pgvectorscale  # Auto-detects pg_diskann on Azure

# Embeddings Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ATULYA_API_EMBEDDINGS_PROVIDER=local
# For local provider:
# ATULYA_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
# For TEI provider:
# ATULYA_API_EMBEDDINGS_TEI_URL=http://localhost:8080

# Reranker Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ATULYA_API_RERANKER_PROVIDER=local
# For local provider:
# ATULYA_API_RERANKER_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# For TEI provider:
# ATULYA_API_RERANKER_TEI_URL=http://localhost:8081

# Observability & Tracing (Optional - disabled by default)
# Enable OpenTelemetry tracing for LLM calls (GenAI semantic conventions)
# ATULYA_API_OTEL_TRACES_ENABLED=true
#
# Local development with Grafana LGTM stack (recommended - see scripts/dev/grafana/README.md)
# ATULYA_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#
# Cloud backends (Grafana Cloud, Langfuse, DataDog, etc.)
# ATULYA_API_OTEL_EXPORTER_OTLP_ENDPOINT=https://your-backend-url
# ATULYA_API_OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer your-token"
#
# Custom service name and environment (optional, defaults: atulya-api, development)
# ATULYA_API_OTEL_SERVICE_NAME=atulya-production
# ATULYA_API_OTEL_DEPLOYMENT_ENVIRONMENT=production

# Entity trajectories (optional — LLM + HMM-style progression per entity; default off)
# When enabled, retain commits enqueue background jobs to recompute trajectories for touched entities.
# Banks can override via bank config API (hierarchical). Requires worker + DB migration for entity_trajectories.
ATULYA_API_ENABLE_ENTITY_TRAJECTORIES=true
ATULYA_API_ENTITY_TRAJECTORY_MAX_FACTS_PER_ENTITY=200
ATULYA_API_ENTITY_TRAJECTORY_FORECAST_HORIZON=5
ATULYA_API_ENTITY_TRAJECTORY_LAPLACE_ALPHA=0.1
ATULYA_API_ENTITY_TRAJECTORY_MIN_FACTS=3
ATULYA_API_ENTITY_TRAJECTORY_ENQUEUE_MAX_ENTITIES=50
ATULYA_API_ENTITY_TRAJECTORY_PROMPT_VERSION=v1
