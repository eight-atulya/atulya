# Atulya Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (Required)
# Supported providers: openai, groq, ollama, gemini, anthropic, anthropic-foundry, lmstudio, vertexai
# ATULYA_API_LLM_PROVIDER=openai
# ATULYA_API_LLM_API_KEY=your-api-key-here
# ATULYA_API_LLM_MODEL=gpt-4o-mini
# ATULYA_API_LLM_BASE_URL=https://api.openai.com/v1

# Example: Anthropic Claude configuration
# ATULYA_API_LLM_PROVIDER=anthropic
# ATULYA_API_LLM_API_KEY=your-anthropic-api-key
# ATULYA_API_LLM_MODEL=claude-sonnet-4-20250514

# Example: Anthropic via Azure AI Foundry
# ATULYA_API_LLM_PROVIDER=anthropic-foundry
# ATULYA_API_LLM_API_KEY=your-azure-ai-foundry-key
# ATULYA_API_LLM_MODEL=claude-sonnet-4-6
# ATULYA_API_LLM_BASE_URL=https://your-endpoint.services.ai.azure.com/anthropic/

# Example: Google Vertex AI configuration
# ATULYA_API_LLM_PROVIDER=vertexai
# ATULYA_API_LLM_MODEL=google/gemini-2.0-flash-001
# ATULYA_API_LLM_VERTEXAI_PROJECT_ID=your-gcp-project-id
# ATULYA_API_LLM_VERTEXAI_REGION=us-central1
# ATULYA_API_LLM_VERTEXAI_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json  # Optional, uses ADC if not set

# Example: LM Studio local configuration (openai/gpt-oss-20b recommended)
ATULYA_API_LLM_PROVIDER=lmstudio
ATULYA_API_LLM_API_KEY=lmstudio
ATULYA_API_LLM_BASE_URL=http://localhost:1234/v1
ATULYA_API_LLM_MODEL=openai/gpt-oss-20b

# LM Studio stability note:
# - Keep reasoning effort at "medium" in your LM Studio/runtime settings.
# - For newer OpenAI-style models, set experts to 8 in LM Studio model settings.
# - Recommended minimum: openai/gpt-oss-20b on RTX 4060 with full GPU offload
#   for okay-ish performance and better accuracy.
# - For long retain jobs on local models, start conservative:
#   ATULYA_API_LLM_MAX_CONCURRENT=1
#   ATULYA_API_RETAIN_LLM_MAX_CONCURRENT=1
#   ATULYA_API_RETAIN_LLM_TIMEOUT=900
#   ATULYA_API_RETAIN_CHUNK_SIZE=2000

# ──────────────────────────────────────────────────────────────────────────────
# Example: llamacpp — built-in GGUF provider (fully offline, no external server)
# ──────────────────────────────────────────────────────────────────────────────
# Runs a llama-cpp-python HTTP subprocess internally. No Ollama/LM Studio needed.
# Supports any GGUF model — including fine-tuned / LoRA adapters.
#
# Install extra deps first:
#   pip install 'atulya-api[local-llm]'
#
# Quickstart (auto-downloads gemma-4-e2b-it-Q4_K_M.gguf ~3.5 GB on first run):
# ATULYA_API_LLM_PROVIDER=llamacpp
#
# Custom model path (recommended for production):
# ATULYA_API_LLM_PROVIDER=llamacpp
# ATULYA_API_LLAMACPP_MODEL_PATH=~/.atulya/models/your-model.gguf
#
# Hardware tiers — tune GPU layers and batch size to your VRAM:
#
#   [Tier 1] Apple Silicon / NVIDIA ≥16 GB  →  full GPU offload
# ATULYA_API_LLAMACPP_GPU_LAYERS=-1          # -1 = all layers on GPU (default)
# ATULYA_API_LLAMACPP_N_BATCH=2048           # safe on 16 GB+
# ATULYA_API_LLAMACPP_FLASH_ATTN=true        # Metal/CUDA only — DO NOT enable on CPU-only
#
#   [Tier 2] NVIDIA 8–12 GB
# ATULYA_API_LLAMACPP_GPU_LAYERS=28          # tune: fewer layers = less VRAM
# ATULYA_API_LLAMACPP_N_BATCH=512            # safe default (conservative)
# ATULYA_API_LLAMACPP_FLASH_ATTN=false
#
#   [Tier 3] CPU-only
# ATULYA_API_LLAMACPP_GPU_LAYERS=0
# ATULYA_API_LLAMACPP_N_BATCH=256
# ATULYA_API_LLAMACPP_FLASH_ATTN=false       # MUST be false on CPU
#
# All llamacpp options (all optional — shown with their defaults):
# ATULYA_API_LLAMACPP_MODEL_PATH=            # Path to .gguf file; unset = auto-download default
# ATULYA_API_LLAMACPP_GPU_LAYERS=-1          # -1 = all layers on GPU, 0 = CPU-only
# ATULYA_API_LLAMACPP_CONTEXT_SIZE=8192      # Context window tokens; reduce if OOM at startup
# ATULYA_API_LLAMACPP_CHAT_FORMAT=           # Chat template (unset = auto-detect from GGUF metadata)
# ATULYA_API_LLAMACPP_N_BATCH=512            # Prompt batch size; 512 safe for <8 GB VRAM
# ATULYA_API_LLAMACPP_FLASH_ATTN=false       # Flash attention — opt-in; requires CUDA or Metal
# ATULYA_API_LLAMACPP_VERBOSE=false          # Log model tensor metadata (very noisy — keep false in prod)
# ATULYA_API_LLAMACPP_NO_GRAMMAR=false       # Disable JSON grammar enforcement (faster, less reliable)
# ATULYA_API_LLAMACPP_LORA_PATH=             # Optional: path to LoRA adapter .gguf for fine-tuned models
# ATULYA_API_LLAMACPP_EXTRA_ARGS=            # Space-separated extra flags forwarded to llama.cpp server
#                                            # Example: "--cache true --threads 8"


ATULYA_API_HOST=0.0.0.0
ATULYA_API_PORT=8888
ATULYA_API_LOG_LEVEL=info

# Brain Configuration [required]
ATULYA_API_BRAIN_ENABLED=true
ATULYA_API_BRAIN_STARTUP_WARMUP=true

# Base Path / Reverse Proxy Support (Optional)
# Set these when deploying behind a reverse proxy with path-based routing
# Example: To deploy at example.com/atulya/, set both to "/atulya"
# ATULYA_API_BASE_PATH=/atulya
# NEXT_PUBLIC_BASE_PATH=/atulya

# Database (Optional - uses embedded pg0 by default)
# ATULYA_API_DATABASE_URL=postgresql://user:pass@host:5432/db
# ATULYA_API_DATABASE_SCHEMA=public  # PostgreSQL schema name (default: public)

# Vector Extension (Optional - uses pgvector by default)
# Options: "pgvector" (default), "vchord", "pgvectorscale" (DiskANN)
# ATULYA_API_VECTOR_EXTENSION=pgvector
# For Azure PostgreSQL with DiskANN:
# ATULYA_API_VECTOR_EXTENSION=pgvectorscale  # Auto-detects pg_diskann on Azure

# Embeddings Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ATULYA_API_EMBEDDINGS_PROVIDER=local
# For local provider:
# ATULYA_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
# For TEI provider:
# ATULYA_API_EMBEDDINGS_TEI_URL=http://localhost:8080
# For Cohere provider:
# ATULYA_API_EMBEDDINGS_PROVIDER=cohere
# ATULYA_API_EMBEDDINGS_COHERE_API_KEY=your-cohere-api-key
# ATULYA_API_EMBEDDINGS_COHERE_MODEL=embed-english-v3.0
# ATULYA_API_EMBEDDINGS_COHERE_OUTPUT_DIMENSIONS=512   # Optional: Matryoshka truncation for embed-v4.0+
#                                                      # When set, uses Cohere v2 API. Values: 256, 512, 1024

# Reranker Configuration (Optional - uses local by default)
# Provider: "local" (default) or "tei" (HuggingFace Text Embeddings Inference)
# ATULYA_API_RERANKER_PROVIDER=local
# For local provider:
# ATULYA_API_RERANKER_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# For TEI provider:
# ATULYA_API_RERANKER_TEI_URL=http://localhost:8081

# Observability & tracing (default: self-hosted Langfuse for LLM OTEL)
# Stack: ./scripts/dev/start-langfuse.sh → http://localhost:3001 (see docker/docker-compose/langfuse/README.md)
# In Langfuse UI: create a project → Settings → API keys → use public + secret below.
ATULYA_API_OTEL_TRACES_ENABLED=true
ATULYA_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3001/api/public/otel
# Build:  echo -n 'pk-lf-xxxxxxxx:sk-lf-xxxxxxxx' | base64   (GNU Linux: add  -w 0  to base64)
ATULYA_API_OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic REPLACE_WITH_BASE64_OF_PK_COLON_SK,x-langfuse-ingestion-version=4"
ATULYA_API_OTEL_SERVICE_NAME=atulya-api
ATULYA_API_OTEL_DEPLOYMENT_ENVIRONMENT=development
# For atulya-worker only, you can set: ATULYA_API_OTEL_SERVICE_NAME=atulya-worker
#
# Alternative: Grafana LGTM (OTLP HTTP on 4318; Grafana UI on 3000 — see scripts/dev/monitoring/README.md)
# ATULYA_API_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# ATULYA_API_OTEL_EXPORTER_OTLP_HEADERS=
#
# Langfuse Cloud (pick your region): https://langfuse.com/docs/opentelemetry/example-opentelemetry-collector
# ATULYA_API_OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel

# Entity trajectories (optional — LLM + HMM-style progression per entity; default off)
# When enabled, retain commits enqueue background jobs to recompute trajectories for touched entities.
# Banks can override via bank config API (hierarchical). Requires worker + DB migration for entity_trajectories.
ATULYA_API_ENABLE_ENTITY_TRAJECTORIES=true
ATULYA_API_ENTITY_TRAJECTORY_MAX_FACTS_PER_ENTITY=200
ATULYA_API_ENTITY_TRAJECTORY_FORECAST_HORIZON=5
ATULYA_API_ENTITY_TRAJECTORY_LAPLACE_ALPHA=0.1
ATULYA_API_ENTITY_TRAJECTORY_MIN_FACTS=3
ATULYA_API_ENTITY_TRAJECTORY_ENQUEUE_MAX_ENTITIES=50
ATULYA_API_ENTITY_TRAJECTORY_PROMPT_VERSION=v1


# Bank-level entity intelligence (optional — super-summary across all bank entities)
# Uses the default/retain LLM unless these dedicated LLM settings are set.
ATULYA_API_ENABLE_ENTITY_INTELLIGENCE=false
ATULYA_API_ENTITY_INTELLIGENCE_TRIGGER_ENTITY_DELTA=8
ATULYA_API_ENTITY_INTELLIGENCE_MIN_ENTITIES=8
ATULYA_API_ENTITY_INTELLIGENCE_MAX_ENTITIES=2000
ATULYA_API_ENTITY_INTELLIGENCE_MAX_CONTEXT_TOKENS=10000
ATULYA_API_ENTITY_INTELLIGENCE_MAX_COMPLETION_TOKENS=4096
ATULYA_API_ENTITY_INTELLIGENCE_PROMPT_VERSION=v2-digital-person-map
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_PROVIDER=lmstudio
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_API_KEY=lmstudio
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_BASE_URL=http://192.168.0.108:1234/v1
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_MODEL=google/gemma-4-e2b:2
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_TIMEOUT=900
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_MAX_RETRIES=3
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_INITIAL_BACKOFF=2
# ATULYA_API_ENTITY_INTELLIGENCE_LLM_MAX_BACKOFF=120

# Observations / consolidation for local LLMs
# These are the first knobs to tighten if background observation generation times out.
# ATULYA_API_CONSOLIDATION_LLM_TIMEOUT=900
# ATULYA_API_CONSOLIDATION_LLM_MAX_CONCURRENT=1
# ATULYA_API_CONSOLIDATION_LLM_BATCH_SIZE=1
# ATULYA_API_CONSOLIDATION_MAX_COMPLETION_TOKENS=1024
# ATULYA_API_CONSOLIDATION_SOURCE_FACTS_MAX_TOKENS=512


# Safe-by-default: admin routes are NOT mounted unless explicitly enabled.
# ATULYA_API_ADMIN_ENABLED=false
# ATULYA_API_SUPERUSER_KEY=<generate with: openssl rand -hex 32>
# ATULYA_API_SUPERUSER_SCHEMA=public
# ATULYA_CP_ADMIN_API_KEY=<same value as ATULYA_API_SUPERUSER_KEY, server-side only>
