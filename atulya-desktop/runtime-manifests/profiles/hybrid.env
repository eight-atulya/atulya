# Atulya Desktop — Hybrid Profile
# Brain: enabled | Remote learning: user-opt-in only | Network: allowed
# Embeddings + reranker stay local. LLM can be remote.

# Database: embedded pg0
ATULYA_API_DATABASE_URL=pg0://atulya-desktop
ATULYA_API_RUN_MIGRATIONS_ON_STARTUP=true

# Network: loopback only (API not exposed publicly)
ATULYA_API_HOST=127.0.0.1
ATULYA_API_PORT=8888

# LLM: remote provider (user configures API key in settings)
ATULYA_API_LLM_PROVIDER=openai
ATULYA_API_SKIP_LLM_VERIFICATION=true

# Embeddings + reranker: local models (keeps offline vector search working)
ATULYA_API_EMBEDDINGS_PROVIDER=local
ATULYA_API_RERANKER_PROVIDER=local

# Brain: enabled
ATULYA_API_BRAIN_ENABLED=true
ATULYA_API_BRAIN_IMPORT_EXPORT_ENABLED=true
ATULYA_API_BRAIN_STARTUP_WARMUP=true
ATULYA_API_BRAIN_HARDWARE_TIER=balanced

# File storage: native
ATULYA_API_FILE_STORAGE_TYPE=native

# MCP + worker
ATULYA_API_MCP_ENABLED=true
ATULYA_API_WORKER_ENABLED=true

# Logging
ATULYA_API_LOG_LEVEL=info
PYTHONUNBUFFERED=1
TRANSFORMERS_VERBOSITY=error
HF_HUB_VERBOSITY=error
TOKENIZERS_PARALLELISM=false
