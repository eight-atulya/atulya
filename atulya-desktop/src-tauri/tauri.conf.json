{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atulya",
  "version": "0.1.0",
  "identifier": "com.atulya.desktop",
  "app": {
    "windows": [
      {
        "title": "Atulya",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8888 http://127.0.0.1:9999; style-src 'self' 'unsafe-inline'"
    }
  },
  "build": {
    "devUrl": "http://localhost:9999",
    "frontendDist": "../app/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "runtime-manifests/**/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "macOS": {
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libssl3", "libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    },
    "shell": {
      "open": true
    }
  }
}
