# =============================================================================
# Atulya Control Plane — Environment Template
# Usage:
#   cp .env.example .env.local
#   Fill in required values, then restart the control plane.
#
# Rules:
#   - Variables WITHOUT "NEXT_PUBLIC_" prefix are server-side only
#   - NEVER add secrets with NEXT_PUBLIC_ — they are exposed to the browser
# =============================================================================


# -----------------------------------------------------------------------------
# [REQUIRED] API Backend
# The FastAPI (atulya-api) base URL the control plane fetches from.
# Default port is 8888 when using scripts/dev/start.sh
# -----------------------------------------------------------------------------
ATULYA_CP_DATAPLANE_API_URL=http://localhost:8888

# Development-only compatibility fallback. In production, leave this false or
# unset and let browser requests authenticate exclusively through the session.
ATULYA_CP_ALLOW_DATAPLANE_API_KEY_FALLBACK=false


# Human and service authorization is resolved by atulya-api. The control plane
# stores only an opaque HTTP-only session cookie and never receives the emergency
# platform key.
ATULYA_CP_PUBLIC_URL=http://localhost:9999
ATULYA_CP_COOKIE_SECURE=false


# -----------------------------------------------------------------------------
# [OPTIONAL] Live web stack (SearXNG + Firecrawl) — Think → Internet panel
# When unset, the panel shows offline and quick search / research are unavailable.
# Align with atulya-api: ATULYA_API_CORTEX_SEARXNG_BASE_URL / ATULYA_API_CORTEX_FIRECRAWL_API_URL
# -----------------------------------------------------------------------------
# ATULYA_CP_INTERNET_SEARXNG_URL=http://127.0.0.1:18080
# ATULYA_CP_INTERNET_FIRECRAWL_URL=http://127.0.0.1:3002


# -----------------------------------------------------------------------------
# [OPTIONAL] Header co-branding
#
# Keep Atulya as the primary logo and add a small customer/company logo beside it.
# Put assets in atulya-control-plane/public/branding/ and reference them by URL path.
# Use only public, non-secret values here: NEXT_PUBLIC_* is sent to the browser.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ATULYA_CP_BRAND_LOGO_SRC=/branding/customer-mark.svg
# NEXT_PUBLIC_ATULYA_CP_BRAND_LOGO_EXTENDED_SRC=/branding/customer-wordmark.svg
# NEXT_PUBLIC_ATULYA_CP_BRAND_LOGO_ALT=Customer name
# NEXT_PUBLIC_ATULYA_CP_BRAND_LOGO_VARIANT=compact  # compact | extended


# -----------------------------------------------------------------------------
# [OPTIONAL] Feature flags (uncomment to override defaults)
# -----------------------------------------------------------------------------
# ATULYA_CP_ENABLE_DREAM=false
# ATULYA_CP_ENABLE_BRAIN_RUNTIME=false
