# =============================================================================
# Atulya Control Plane — Environment Template
# Usage:
#   cp .env.example .env.local
#   Fill in required values, then restart the control plane.
#
# Rules:
#   - Variables WITHOUT "NEXT_PUBLIC_" prefix are server-side only
#   - NEVER add secrets with NEXT_PUBLIC_ — they are exposed to the browser
# =============================================================================


# -----------------------------------------------------------------------------
# [REQUIRED] API Backend
# The FastAPI (atulya-api) base URL the control plane fetches from.
# Default port is 8888 when using scripts/dev/start.sh
# -----------------------------------------------------------------------------
ATULYA_CP_DATAPLANE_API_URL=http://localhost:8888


# -----------------------------------------------------------------------------
# [REQUIRED for Admin UI] Admin API Key
#
# Must match ATULYA_API_SUPERUSER_KEY set on the atulya-api side.
# Server-side only — never sent to the browser.
#
# Generate a key:
#   openssl rand -hex 32
#
# Admin UI will be accessible at:
#   http://localhost:9999/admin
#
# If this is empty or missing, /admin returns 404 (safe default).
# -----------------------------------------------------------------------------
ATULYA_CP_ADMIN_API_KEY=


# -----------------------------------------------------------------------------
# [OPTIONAL] Feature flags (uncomment to override defaults)
# -----------------------------------------------------------------------------
# ATULYA_CP_ENABLE_DREAM=false
# ATULYA_CP_ENABLE_BRAIN_RUNTIME=false
