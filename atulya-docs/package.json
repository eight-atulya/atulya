{
  "name": "atulya-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "node ./scripts/run-docusaurus.cjs",
    "start": "node ./scripts/run-docusaurus.cjs start",
    "build": "node ./scripts/run-docusaurus.cjs build",
    "swizzle": "node ./scripts/run-docusaurus.cjs swizzle",
    "deploy": "node ./scripts/run-docusaurus.cjs deploy",
    "clear": "node ./scripts/run-docusaurus.cjs clear",
    "serve": "node ./scripts/run-docusaurus.cjs serve",
    "write-translations": "node ./scripts/run-docusaurus.cjs write-translations",
    "write-heading-ids": "node ./scripts/run-docusaurus.cjs write-heading-ids",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-common": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@easyops-cn/docusaurus-search-local": "0.52.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "raw-loader": "^4.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redocusaurus": "^2.5.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "overrides": {
    "openapi-to-postmanv2": {
      "js-yaml": "4.1.1"
    }
  }
